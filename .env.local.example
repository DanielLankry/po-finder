# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Email (Resend)
RESEND_API_KEY=re_your-resend-key

# Admin
ADMIN_SECRET=long-random-string

# Payment provider — HYP (YaadPay)
# For local dev, HYP publishes a public test merchant you can drop in:
#   HYP_MASOF=0010131918
#   HYP_PASSP=yaad
#   HYP_API_KEY=7110eda4d09e062aa5e4a390b0a572ac0d2c0220
HYP_MASOF=
HYP_PASSP=
HYP_API_KEY=

# Public site origin — used for HYP success/error/cancel redirect URLs.
# Must match your production domain exactly.
NEXT_PUBLIC_SITE_URL=https://pokarov.co.il
